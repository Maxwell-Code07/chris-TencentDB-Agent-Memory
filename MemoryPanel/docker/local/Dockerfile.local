# syntax=docker/dockerfile:1
# ──────────────────────────────────────────────────────────────────────
# team-memory-control — 本地部署模式镜像 (Panel Control HTTP :8123)
#
# 特点（本地模式）：
#   - 用 tsx 直跑 src/index.ts（stateless panel，入口 src/panel/）；
#   - 安装全量依赖；原生依赖 better-sqlite3 需 python3/make/g++ 编译；
#   - web/ 前端在独立 stage 构建，产物由 UI_DIST_DIR 静态托管。
#
# 注意：构建上下文为仓库根（镜像会打包当前工作树）。
#
# Build:
#   docker build --build-arg PANEL_UI=web -t team-memory-control:local \
#     -f docker/local/Dockerfile.local .
# Run:
#   docker run -d -p 8123:8123 \
#     -e UI_DIST_DIR=./web/dist \
#     -e METADATA_INSTANCES_CONFIG=/app/config/metadata-instances.json \
#     team-memory-control:local
# ──────────────────────────────────────────────────────────────────────
ARG PANEL_UI=web

# ── base：node:22-slim + 腾讯云 apt 镜像 + 原生编译工具链 ──────────────
FROM node:22-slim AS base

RUN sed -i 's|deb.debian.org|mirrors.tencent.com|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || \
    sed -i 's|deb.debian.org|mirrors.tencent.com|g' /etc/apt/sources.list 2>/dev/null || true

# better-sqlite3 原生编译 + git（可选）+ curl（healthcheck）
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
      python3 make g++ git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ── ui-builder：只构建被选中的面板（web 或 frontend）→ /ui/dist ────────
# WEB_UI=1（默认）：正常构建面板 UI。
# WEB_UI=0：跳过面板 UI 构建，生成占位 dist。面板 UI 依赖 @tencent/* 内部包，
#   公共 npm 镜像没有；离线/无内部源时用它绕过。control 后端与 /health、/api/
#   不受影响，仅静态面板不可用（见 src/panel/http/app.ts：/api、/health 优先返回）。
FROM base AS ui-builder
ARG PANEL_UI
ARG WEB_UI=1
COPY ${PANEL_UI}/ /ui/
WORKDIR /ui
RUN --mount=type=cache,id=npm-tmc-ui,target=/root/.npm \
    if [ "$WEB_UI" = "0" ]; then \
      echo "[ui-builder] WEB_UI=0 → 跳过面板 UI 构建，生成占位 dist"; \
      mkdir -p /ui/dist && \
      printf '<!doctype html><meta charset="utf-8"><title>panel disabled</title><body>Control panel UI is disabled in this image (WEB_UI=0).</body>' > /ui/dist/index.html; \
    else \
      npm install --no-audit --no-fund && npm run build; \
    fi

# ── runtime：control 后端（tsx 直跑 src/index.ts） ────────────────────
FROM base AS runtime
ARG PANEL_UI

# 整仓 COPY，再 install（原生 better-sqlite3 在此镜像编译）
COPY . .
RUN --mount=type=cache,id=npm-tmc,target=/root/.npm \
    npm install --no-audit --no-fund

# 把选中的面板产物放到 Panel 静态托管目录
COPY --from=ui-builder /ui/dist ./${PANEL_UI}/dist
ENV UI_DIST_DIR=./${PANEL_UI}/dist

ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=8123
RUN mkdir -p /app/logs /data
EXPOSE 8123

HEALTHCHECK --interval=15s --timeout=10s --retries=20 --start-period=60s \
  CMD curl -fsS http://127.0.0.1:8123/health || exit 1

# control 以 tsx 直跑源码（stateless panel，入口 src/panel/）
CMD ["node", "--import", "tsx/esm", "src/index.ts"]
