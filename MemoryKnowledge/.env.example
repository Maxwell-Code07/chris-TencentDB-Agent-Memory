# Knowledge Service 配置
# 用法：cp .env.example .env && 编辑 .env
# .env 由 src/config.ts 顶部的 `import 'dotenv/config'` 自动加载

# ═══ HTTP Server ═══
PORT=8421
API_PREFIX=/v3
LOG_LEVEL=debug

# ═══ 数据存储 ═══
# 数据根目录：git clone、wiki 素材、BM25 索引、SQLite 都在此目录下
KNOWLEDGE_DATA_DIR=./data
# SQLite 数据库路径（4 张表：knowledge_wiki / knowledge_code_graph / *_audit）
KNOWLEDGE_DB_PATH=./data/knowledge.db

# ═══ LLM 配置（wiki ingest 必需，code-graph 不依赖） ═══
# LLM_MODE：全局默认路由（per-instance llm_binding 永远优先于此）
#   proxy（默认）：走云端 Proxy，用 TMC 推送的 knowledge-service key 计费。
#                  KS 本地无需启动 Proxy；没绑定则报错（不静默直连）。
#   custom       ：用下面的 LLM_BASE_URL/LLM_API_KEY 直连自带端点（BYO）。
LLM_MODE=proxy
LLM_PROVIDER=custom
LLM_MODEL=Memory-Model
LLM_MAX_TOKENS=32768
LLM_TIMEOUT_MS=1200000

# 仅 LLM_MODE=custom 时需要：
LLM_API_KEY=
LLM_BASE_URL=

# ═══ MCP Server（src/mcp/server.ts 专用） ═══
# MCP server 通过 HTTP 调用本服务 API，这里配置转发目标
KNOWLEDGE_API_URL=http://localhost:8421
# KNOWLEDGE_API_TOKEN=optional-bearer-token

# ═══ 与管控（team-memory-control）对接 ═══
# TMC + KS 部署时以下两项必须显式配置。代码中的默认值均为空：
# - PUBLIC_BASE_URL 必须是 Agent 可访问、且包含 /v3 的地址；
# - CALLBACK_URL 只能是 TMC 根地址，程序会自动追加 /api/v1/knowledge/status-callback。
# Docker 部署请用 CLI：--public-url / --tmc-callback（见 docs/deployment.md）
KNOWLEDGE_PUBLIC_BASE_URL=http://localhost:8421/v3
TMC_CALLBACK_URL=http://localhost:8123

# 管控侧配置（不在本服务读取）：
#   KNOWLEDGE_SERVICE_URL=http://127.0.0.1:8421
