{
  "name": "@tencentdb-agent-memory/knowledge-service",
  "version": "0.1.0",
  "description": "Standalone knowledge service — Code-Graph + LLM-Wiki engine for user-side deployment",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "knowledge-server": "./bin/server.mjs",
    "knowledge-mcp": "./bin/mcp.mjs"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.95",
    "@ai-sdk/openai": "^3.0.53",
    "@colbymchenry/codegraph": "^1.2.0",
    "@hono/node-server": "^1.14.0",
    "@hono/swagger-ui": "^0.5.2",
    "@langfuse/otel": "5.6.0",
    "@langfuse/tracing": "5.6.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@node-rs/jieba": "^2.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.219.0",
    "ai": "^6.0.164",
    "better-sqlite3": "^11.10.0",
    "crc-32": "^1.2.2",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.44.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "hono": "^4.7.0",
    "js-tiktoken": "^1.0.18",
    "js-yaml": "^4.2.0",
    "json5": "^2.2.3",
    "lru-cache": "^11.0.0",
    "minisearch": "^7.2.0",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
